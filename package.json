{
  "name": "joblio",
  "version": "0.1.0",
  "private": true,
  "description": "Joblio local tracker backend + UI",
  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "node ./scripts/build-frontend-bundle.js",
    "build:frontend:check": "node ./scripts/check-frontend-bundle.js",
    "preflight": "node ./scripts/preflight.js",
    "security": "npm run security:check && npm run test:security",
    "security:check": "node ./scripts/security-check.js",
    "setup": "node ./scripts/setup.js",
    "reconfigure": "node ./scripts/setup.js --reconfigure",
    "start": "node ./scripts/start.js",
    "tls:gen": "node ./scripts/gen-local-tls.js",
    "test:security": "node --test ./scripts/security-tests.js ./scripts/restore-tests.js",
    "validate:release": "node ./scripts/validate-release.js",
    "smoke": "node ./scripts/smoke-test.js",
    "backup": "node ./scripts/backup.js",
    "restore": "node ./scripts/restore.js"
  }
}
